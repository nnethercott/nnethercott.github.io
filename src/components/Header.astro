---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<header>
  <div class="flex justify-start">
    <div class="flex justify-end gap-4 my-16 mx-auto w-full md:w-1/2">
    <a href="/">
        <img class="w-28 h-28" src="/logo.jpg" alt="textures" />
      </a>

      <div class="flex flex-col justify-end items-end ml-auto gap-4">
        <div class= 'flex flex-col justify-end items-end'>
          <h2 class="text-2xl font-medium"><a>$ {SITE_TITLE}</a></h2>
          <p class="text-gray-600">{SITE_DESCRIPTION}</p>
        </div>

        <div>
          <HeaderLink href="/" class = "pr-2">blog</HeaderLink>
          <HeaderLink href="/about">about</HeaderLink>
        </div>
      </div>
    </div>
  </div>
</header>

